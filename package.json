{
  "name": "admin",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "PagibleAI CMS admin backend",
  "keywords": [
    "cms",
    "vue",
    "vuetify"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "test:unit": "cypress run --component",
    "test:unit:dev": "cypress open --component",
    "lint": "eslint --fix",
    "format": "prettier --write src/",
    "gettext:extract": "vue-gettext-extract",
    "gettext:compile": "vue-gettext-compile"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@ckeditor/ckeditor5-vue": "^7.3.1",
    "@he-tree/vue": "^2.10",
    "@vue/apollo-option": "^4.2",
    "apollo-link-batch-http": "^1.2",
    "apollo-upload-client": "^18.0.1",
    "chart.js": "^4.5.1",
    "ckeditor5": "^47.6.1",
    "cropperjs": "^1.5.13",
    "diff": "^8.0",
    "dompurify": "^3.3.3",
    "fast-deep-equal": "^3.1.3",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-markdown": "^2.1.2",
    "pinia": "^3.0",
    "vite-plugin-vuetify": "^2.1",
    "vue": "^3.5",
    "vue-chartjs": "^5.3.3",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.0",
    "vue3-gettext": "^4.0.0-beta.1",
    "vue3-observe-visibility": "^1.0.6",
    "vuetify": "^4.0"
  },
  "devDependencies": {
    "@mdi/js": "^7.4",
    "@vitejs/plugin-vue": "^6.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "cypress": "^15.12.0",
    "eslint": "^10.0",
    "eslint-plugin-vue": "^10.8",
    "prettier": "^3.8",
    "sass": "^1.98",
    "start-server-and-test": "^2.1",
    "vite": "^7.3"
  }
